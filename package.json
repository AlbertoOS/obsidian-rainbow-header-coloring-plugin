{
	"name": "obsidian-header-coloring",
	"version": "1.0.0",
	"description": "Color your markdown headers (H1–H6) in Obsidian with customizable palettes",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"install-test": "bash scripts/install-to-test-vault.sh"
	},
	"keywords": [],
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/node": "^25.9.1",
		"esbuild": "0.28.0",
		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "17.6.0",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.59.4",
		"@eslint/js": "9.30.1",
		"jiti": "2.7.0"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
